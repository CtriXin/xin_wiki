{
  "name": "ai-quota-monitor",
  "version": "1.0.0",
  "description": "AI Quota Monitor - 实时监控各大 AI 平台配额使用情况",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "node --watch backend/server.js",
    "tray": "electron tray-app.js",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir"
  },
  "keywords": [
    "ai",
    "quota",
    "monitor",
    "kimi",
    "minimax",
    "bailian"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.aiquotamonitor.app",
    "productName": "AI Quota Monitor",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "files": [
      "backend/**/*",
      "frontend/**/*",
      "node_modules/**/*",
      "package.json",
      "tray-app.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "config.example.json",
        "to": "config.json"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
